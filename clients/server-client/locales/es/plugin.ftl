# Poly Server client plugin — Spanish translations
# All keys MUST be prefixed with "plugin-poly-"

# --- Signup picker card ---
plugin-poly-signup-name = Poly Server
plugin-poly-signup-desc = Conéctate a un servidor Poly alojado por ti mismo.

# --- Signup page ---
plugin-poly-signup-title = Añadir cuenta de Poly Server
plugin-poly-signup-description = Ingresa la URL de tu servidor para conectarte. Poly usará tu clave de identidad del dispositivo para iniciar sesión, y las cuentas nuevas de Poly Server también requieren una dirección de correo electrónico.
plugin-poly-signup-back = ← Elegir backend
plugin-poly-signup-url-label = URL del servidor
plugin-poly-signup-url-placeholder = http://127.0.0.1:7080

# --- Paso 1: URL + Conectar ---
plugin-poly-connect-btn = Conectar

# --- Paso 2: Formulario de registro ---
plugin-poly-signup-no-account-desc = No se encontró ninguna cuenta para tu clave de identidad en este servidor. Elige un nombre de usuario y una dirección de correo electrónico para crear una cuenta nueva.
plugin-poly-existing-accounts-desc = Este servidor ya tiene una o más cuentas vinculadas a tu clave de identidad. Elige una para iniciar sesión o crea otra cuenta en este servidor.
plugin-poly-signup-another-account-desc = Esta clave de identidad ya está vinculada a otras cuentas en este servidor. Elige un nombre de usuario y una dirección de correo electrónico para crear una cuenta adicional.
plugin-poly-signup-username-label = Nombre de usuario
plugin-poly-signup-username-placeholder = alice
plugin-poly-signup-email-label = Dirección de correo electrónico
plugin-poly-signup-email-placeholder = alice@example.com
plugin-poly-signup-displayname-label = Nombre para mostrar
plugin-poly-signup-displayname-placeholder = Alice
plugin-poly-create-account-btn = Crear cuenta
plugin-poly-create-another-account-btn = Crear otra cuenta
plugin-poly-signup-back-btn = ← Volver

# --- Compartido ---
plugin-poly-signup-connecting = Conectando…
plugin-poly-signup-no-identity = Poly no pudo preparar una clave de identidad para el registro.

# --- Página de ajustes del plugin ---
plugin-poly-title = Poly Server
plugin-poly-settings-description = Configura las opciones de conexión para el backend de Poly Server.
plugin-poly-setting-websocket-label = Usar WebSocket para eventos en tiempo real
plugin-poly-setting-websocket-desc = Cuando está activado, Poly abre una conexión WebSocket persistente para recibir mensajes y eventos al instante. Deactivar para volver al sondeo HTTP. Requiere volver a conectar o reiniciar la aplicación para tomar efecto.

