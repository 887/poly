# Poly Server client plugin — German translations
# All keys MUST be prefixed with "plugin-poly-"

# --- Signup picker card ---
plugin-poly-signup-name = Poly Server
plugin-poly-signup-desc = Verbinde dich mit einem selbst gehosteten Poly-Server.

# --- Signup page ---
plugin-poly-signup-title = Poly-Server-Konto hinzufügen
plugin-poly-signup-description = Gib deine Server-URL ein. Poly verwendet deinen Geräte-Identitätsschlüssel zur Anmeldung, und neue Poly-Server-Konten benötigen zusätzlich eine E-Mail-Adresse.
plugin-poly-signup-back = ← Backend wählen
plugin-poly-signup-url-label = Server-URL
plugin-poly-signup-url-placeholder = http://127.0.0.1:7080

# --- Schritt 1: URL + Verbinden ---
plugin-poly-connect-btn = Verbinden

# --- Schritt 2: Registrierungsformular ---
plugin-poly-signup-no-account-desc = Für deinen Identitätsschlüssel wurde auf diesem Server kein Konto gefunden. Wähle einen Benutzernamen und eine E-Mail-Adresse, um ein neues Konto zu erstellen.
plugin-poly-existing-accounts-desc = Auf diesem Server sind bereits ein oder mehrere Konten mit deinem Identitätsschlüssel verknüpft. Wähle eines zum Anmelden oder erstelle ein weiteres Konto auf diesem Server.
plugin-poly-signup-another-account-desc = Dieser Identitätsschlüssel ist auf diesem Server bereits mit anderen Konten verknüpft. Wähle einen Benutzernamen und eine E-Mail-Adresse, um ein zusätzliches Konto zu erstellen.
plugin-poly-signup-username-label = Benutzername
plugin-poly-signup-username-placeholder = alice
plugin-poly-signup-email-label = E-Mail-Adresse
plugin-poly-signup-email-placeholder = alice@example.com
plugin-poly-signup-displayname-label = Anzeigename
plugin-poly-signup-displayname-placeholder = Alice
plugin-poly-create-account-btn = Konto erstellen
plugin-poly-create-another-account-btn = Weiteres Konto erstellen
plugin-poly-signup-back-btn = ← Zurück

# --- Gemeinsam ---
plugin-poly-signup-connecting = Verbinde…
plugin-poly-signup-no-identity = Poly konnte keinen Identitätsschlüssel für die Registrierung vorbereiten.

# --- Plugin-Einstellungsseite ---
plugin-poly-title = Poly Server
plugin-poly-settings-description = Verbindungsoptionen für das Poly-Server-Backend konfigurieren.
plugin-poly-setting-websocket-label = WebSocket für Echtzeitereignisse verwenden
plugin-poly-setting-websocket-desc = Wenn aktiviert, öffnet Poly eine persistente WebSocket-Verbindung, um Nachrichten und Ereignisse sofort zu empfangen. Deaktivieren, um auf HTTP-Polling zurückzufallen. Zum Übernehmen ist eine Neuverbindung oder ein Neustart der App erforderlich.

# --- Kontoprofil-Tab ---
plugin-poly-profile-title = Profil
plugin-poly-profile-section-desc = Verwalten Sie Ihre Poly-Server-Profilinformationen.
plugin-poly-profile-avatar-label = Profilbild
plugin-poly-profile-display-name-label = Anzeigename
plugin-poly-profile-display-name-desc = Ihr Anzeigename ist für andere Benutzer auf diesem Server sichtbar.
plugin-poly-profile-background-label = Server-Banner / Hintergrund
plugin-poly-profile-background-desc = Bannerbild auf Ihrem Profil (demnächst verfügbar).
plugin-poly-profile-status-label = Aktueller Status
plugin-poly-profile-status-desc = Ihre Verfügbarkeit für andere Benutzer.
plugin-poly-profile-status-online = Online
plugin-poly-profile-status-away = Abwesend
plugin-poly-profile-status-dnd = Nicht stören
plugin-poly-profile-status-appear-offline = Als offline anzeigen
plugin-poly-profile-save = Profil speichern
plugin-poly-profile-saved = Profil gespeichert!
plugin-poly-profile-avatar-coming-soon = Avatar-Upload demnächst verfügbar.
plugin-poly-profile-banner-coming-soon = Banner-Upload demnächst verfügbar.

