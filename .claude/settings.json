{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": ["/tmp", "/dev/null"],
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*"
    ]
  }
}
