# Rust build artifacts
/target/
/target
**/target/
**/target

# Cargo lock — keep for binaries, optional for libraries
# Cargo.lock  # We keep this committed for reproducible builds

# IDE
.idea/
*.iml
.vscode/.history/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local

# Database files
*.db
*.db-wal
*.db-shm
data/

# Poly server data (local runtime artifacts)
# Lockfile and write-ahead-log (remove from repo history if already committed)
/poly-server-data/LOCK
/poly-server-data/wal/

# Node.js (for Electron wrapper)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Build outputs
dist/
build/
# Exception: lint-gate keeps its scanners in crates/lint-gate/build/
# so the `#[path = "build/foo.rs"] mod foo` layout in build.rs works.
!crates/lint-gate/build/
!crates/lint-gate/build/*.rs
# Auto-generated by build.rs in release builds only — individual CSS files are the source of truth
crates/core/assets/tailwind.css
# Auto-generated by build.rs — CSS asset references for Dioxus hot-reload
crates/core/src/ui/css.rs
*.apk
*.ipa
*.app
*.dmg
*.exe
*.msi
*.deb
*.rpm
*.AppImage

# Coverage
*.profraw
lcov.info
coverage/

# Temporary files
tmp/
temp/

# Playwright test results
test-results/
playwright-report/

# Source sprite sheets (individual PNGs are committed instead)
clients/demo/assets/animals.png

# MCP devtools screenshots (saved locally, not committed)
devtools-screenshots/
# Local devtools app log created by the devtools launcher
.devtools-app.log
.playwright-mcp/
rust_out
