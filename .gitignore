# Rust build artifacts
/target/
/target
**/target/
**/target

# Cargo lock — keep for binaries, optional for libraries
# Cargo.lock  # We keep this committed for reproducible builds

# IDE
.idea/
*.iml
.vscode/.history/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local

# Database files
*.db
*.db-wal
*.db-shm
data/

# Poly server data (local runtime artifacts)
# Lockfile and write-ahead-log (remove from repo history if already committed)
/poly-server-data/LOCK
/poly-server-data/wal/

# Node.js (for Electron wrapper)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Build outputs
dist/
build/
# Exception: lint-gate keeps its scanners in crates/lint-gate/build/
# so the `#[path = "build/foo.rs"] mod foo` layout in build.rs works.
!crates/lint-gate/build/
!crates/lint-gate/build/*.rs
# Auto-generated by build.rs in release builds only — individual CSS files are the source of truth
crates/core/assets/tailwind.css
# Auto-generated by build.rs — CSS asset references for Dioxus hot-reload
crates/core/src/ui/css.rs
*.apk
*.ipa
*.app
*.dmg
*.exe
*.msi
*.deb
*.rpm
*.AppImage

# Coverage
*.profraw
lcov.info
coverage/

# Temporary files
tmp/
temp/

# Playwright test results
test-results/
playwright-report/

# Source sprite sheets (individual PNGs are committed instead)
clients/demo/assets/animals.png

# MCP devtools screenshots (saved locally, not committed)
devtools-screenshots/
# Local devtools app log created by the devtools launcher
.devtools-app.log
.playwright-mcp/
rust_out

# Auto-generated by crates/core/build.rs from workspace locales/
crates/core/src/i18n/baked_locales.rs

# E2E harness per-run artefacts (PID files, logs, isolated SQLite, results)
tests/e2e/.run/

# Reddit fixture binaries — captured HTML stays in the repo, but raw
# PNGs / JPGs / favicons / award images scraped during fixture capture
# don't need to ride along (parser layer doesn't read images).
clients/reddit/tests/fixtures/*.png
clients/reddit/tests/fixtures/*.jpg
clients/reddit/tests/fixtures/*.jpeg
clients/reddit/tests/fixtures/*.gif
clients/reddit/tests/fixtures/*.webp
clients/reddit/tests/fixtures/*.ico

# Stray UUID-named drops in clients/demo/assets — defensive guard against
# accidental screenshot writes (real demo avatars use named files like
# `cat.png`, `lemming.png` — UUID names are always accidents). Existing
# tracked UUID-named assets remain tracked; this rule only prevents
# new ones.
clients/demo/assets/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-*-*-*-*.png
clients/demo/assets/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-*-*-*-*.jpg
