# Poly Backup Server — Environment Variables
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#   nano .env
#   docker compose up -d

# ── Required ──────────────────────────────────────────────────────────────────

# Server-wide access passphrase. Shared out-of-band by the server admin
# (e.g. published on a private page, sent via Signal). All clients must know
# this passphrase to register and sync. Never sent to the server in plaintext
# after setup — only used as part of the PoW auth handshake.
POLY_PASSPHRASE=change-me-before-deploying

# Admin UI password. Used to log in to the admin panel at /.
POLY_ADMIN_PASSWORD=change-me-too

# ── Networking ────────────────────────────────────────────────────────────────

# Host port to expose (maps to internal 8080). Change if 8080 is taken.
POLY_BIND_PORT=8080

# ── Account Limits ────────────────────────────────────────────────────────────

# Maximum number of registered public keys. 0 = unlimited.
# Set to a small number (e.g. 5) to limit who can sync to this server.
POLY_MAX_ACCOUNTS=0

# ── Token Lifetime ────────────────────────────────────────────────────────────

# Days of inactivity before a session token expires (rolling window).
# Default: 365 (one year). A token used today expires N days from today.
POLY_TOKEN_EXPIRY_DAYS=365

# ── Proof of Work ─────────────────────────────────────────────────────────────

# PoW difficulty in leading zero bits. Higher = harder challenge for new clients.
# Default: 20 (~1 million SHA-256 hashes). Range: 8 (fast) to 28 (very slow).
# Lower values make registration faster but reduce spam protection.
POLY_POW_DIFFICULTY=20

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Maximum failed auth attempts per IP before triggering 429 Too Many Requests.
POLY_RATE_LIMIT_MAX=5

# Rate-limit window in seconds. After this window, the counter resets.
POLY_RATE_LIMIT_WINDOW_SECS=3600

# ── Branding ─────────────────────────────────────────────────────────────────

# Display name shown in the admin UI and API responses.
POLY_SERVER_NAME=My Poly Backup Server

# ── Admin UI ─────────────────────────────────────────────────────────────────

# Username for the admin panel login form.
POLY_ADMIN_USER=admin
