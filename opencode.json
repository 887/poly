{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "opencode",
    "github-copilot"
  ],
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "mcp": {
    "poly-memory": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--bin",
        "poly-memory-mcp",
        "--manifest-path",
        "/home/laragana/workspcacemsg/Cargo.toml",
        "--",
        "mcp"
      ],
      "enabled": true
    },
    "poly-desktop": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--bin",
        "poly-desktop-devtools-mcp",
        "--manifest-path",
        "/home/laragana/workspcacemsg/Cargo.toml"
      ],
      "enabled": true
    },
    "poly-web": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--bin",
        "poly-web-devtools-mcp",
        "--manifest-path",
        "/home/laragana/workspcacemsg/Cargo.toml"
      ],
      "enabled": true
    },
    "poly-electron": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--bin",
        "poly-electron-devtools-mcp",
        "--manifest-path",
        "/home/laragana/workspcacemsg/Cargo.toml"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics"
      ],
      "enabled": true
    }
  },
