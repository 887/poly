// Poly Messenger Plugin Interface
//
// This WIT file is the canonical interface definition for all messenger
// backend plugins. It mirrors the ClientBackend trait in poly-client
// and defines the contract between the host (poly-core) and guest (plugins).
//
// Package: poly:messenger@0.1.0
// Decision: D21 — WASM Plugin Backends

package poly:messenger@0.1.0;

// ─── Shared Types Interface ────────────────────────────────────────

/// All types shared between host and guest.
interface types {
    /// Online presence status for a remote user.
    enum presence-status {
        online,
        idle,
        do-not-disturb,
        invisible,
        offline,
    }

    /// The type of a channel.
    ///
    /// `text`, `voice`, `video`, `forum`, `hacker-news`, and `code` are the
    /// original variants. `thread` covers Discord threads (public, private,
    /// and announcement threads). `announcement` covers Discord announcement /
    /// news channels (GUILD_ANNOUNCEMENT, type 5).
    enum channel-type {
        text,
        voice,
        video,
        /// Forum channel (Lemmy/Reddit-style: posts with threaded comments).
        forum,
        /// Hacker News–style feed channel (title + URL + score + comments).
        hacker-news,
        /// Code repository explorer (file tree + file content view).
        code,
        /// Thread within a text or forum channel (Discord PUBLIC_THREAD,
        /// PRIVATE_THREAD, ANNOUNCEMENT_THREAD — types 10/11/12).
        thread,
        /// Announcement / news channel (Discord GUILD_ANNOUNCEMENT, type 5).
        announcement,
    }

    /// Kind of a file system entry returned by `list-files`.
    enum file-kind {
        file,
        directory,
        symlink,
        submodule,
    }

    /// File / directory entry returned by `list-files`.
    record file-entry {
        path: string,
        name: string,
        kind: file-kind,
        size: u64,
    }

    /// Raw file content returned by `read-file`.
    record file-content {
        path: string,
        bytes: list<u8>,
        truncated: bool,
    }

    /// Output of a host-mediated subprocess invocation.
    record exec-output {
        exit-code: s32,
        stdout: list<u8>,
        stderr: list<u8>,
    }

    /// Which screen the UI should navigate to after the backend loads.
    enum landing-page {
        /// Per-account overview (the plugin's `get-account-overview-view`).
        /// Default for every backend; declare a different variant only when
        /// the client genuinely wants a different first surface.
        overview,
        direct-messages,
        first-server,
    }

    /// Capability flags describing what a backend supports. Used by the UI
    /// to hide controls that don't make sense for a given backend (e.g.
    /// the mic/speaker buttons for read-only news feeds).
    record backend-capabilities {
        supports-voice: bool,
        supports-video: bool,
        supports-dms: bool,
        supports-groups: bool,
        supports-send-messages: bool,
        supports-presence: bool,
        supports-search: bool,
        supports-reactions: bool,
        supports-typing-indicators: bool,
        supports-file-upload: bool,
        landing: landing-page,
    }

    /// Self-declared plugin manifest. Purely informational — the host does
    /// NOT enforce these declarations at runtime; they exist so users can
    /// inspect what a loaded plugin says it will do.
    record plugin-manifest {
        /// Subprocess programs the plugin spawns via `exec-command`.
        exec-programs: list<string>,
        /// HTTP host patterns the plugin calls (e.g. "api.github.com",
        /// "*.github.com"). Empty list means no HTTP.
        http-hosts: list<string>,
        /// Free-text description of the plugin and its access needs.
        description: string,
        /// Optional homepage / source URL.
        homepage: option<string>,
    }

    /// The user-chosen availability / presence status for an account.
    enum account-presence {
        online,
        away,
        do-not-disturb,
        appear-offline,
        offline,
    }

    /// Log level for host logging import.
    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    /// A user on a messaging platform.
    ///
    /// D17 — `backend` is a plugin-provided slug string (formerly the
    /// `backend-type` enum, now removed).
    record user {
        id: string,
        display-name: string,
        avatar-url: option<string>,
        presence: presence-status,
        backend: string,
    }

    /// A channel category / folder within a server.
    record category {
        id: string,
        name: string,
        channel-ids: list<string>,
    }

    /// A server / community / workspace.
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record server {
        id: string,
        name: string,
        icon-url: option<string>,
        banner-url: option<string>,
        categories: list<category>,
        backend: string,
        unread-count: u32,
        /// Total @mention count across all channels (sum of channel mention-counts).
        /// Distinct from unread-count: only counts direct @mentions.
        mention-count: u32,
        account-id: string,
        account-display-name: string,
        /// Backend-designated welcome / default channel (Discord
        /// system-channel-id, Matrix m.room.tombstone alternative, etc).
        /// When set, the host prefers this for "no channel selected" deep
        /// links and stale-URL fallbacks before falling back to the first
        /// text channel. `None` means no opinion — host picks first text.
        default-channel-id: option<string>,
    }

    /// A tag available in a forum channel.
    record forum-tag {
        id: string,
        name: string,
        /// Unicode emoji or custom emoji ID.
        emoji: option<string>,
        /// Only moderators can apply this tag when true.
        moderated: bool,
    }

    /// Thread metadata for a thread channel or a message that has a thread.
    record thread-metadata {
        archived: bool,
        auto-archive-minutes: u32,
        /// RFC3339 timestamp when the thread was archived; absent if not archived.
        archived-at: option<string>,
        locked: bool,
        /// RFC3339 creation timestamp.
        created-at: string,
    }

    /// Lightweight thread info carried on a message or as a thread channel summary.
    record thread-info {
        thread-id: string,
        parent-channel-id: string,
        message-count: u32,
        member-count: u32,
    }

    /// Sort order for forum channel posts.
    enum forum-sort-order {
        /// Sort by most recent activity.
        latest-activity,
        /// Sort by creation date.
        creation-date,
    }

    /// A forum post (thread within a forum channel).
    record forum-post {
        thread: thread-info,
        /// Tag IDs applied to this post.
        applied-tags: list<string>,
        /// ID of the starter message (first post in the thread).
        starter-message-id: option<string>,
    }

    /// A channel within a server.
    record channel {
        id: string,
        name: string,
        channel-type: channel-type,
        server-id: string,
        unread-count: u32,
        /// Number of @mention notifications in this channel.
        /// Distinct from unread-count: only counts direct @mentions by @username, @here, @all.
        mention-count: u32,
        last-message-id: option<string>,
        /// For forum channels: available tags. Empty list for non-forum channels.
        forum-tags: option<list<forum-tag>>,
        /// For thread channels: ID of the parent text or forum channel.
        parent-channel-id: option<string>,
        /// For thread channels: thread metadata.
        thread-metadata: option<thread-metadata>,
    }

    /// A file attachment in a message.
    record attachment {
        id: string,
        filename: string,
        content-type: string,
        url: string,
        size: u64,
    }

    /// Lightweight preview metadata for a replied-to message.
    record message-reply-preview {
        message-id: string,
        author-id: string,
        author-display-name: string,
        author-avatar-url: option<string>,
        snippet: string,
    }

    /// A reaction on a message.
    record reaction {
        emoji: string,
        count: u32,
        me: bool,
    }

    /// A custom emoji available to the active channel/account.
    record custom-emoji {
        id: string,
        shortcode: string,
        image-url: option<string>,
        unicode-fallback: option<string>,
        animated: bool,
        server-id: option<string>,
        source-name: option<string>,
    }

    /// A sticker available to the active channel/account.
    record sticker-item {
        id: string,
        name: string,
        image-url: string,
        pack-name: option<string>,
        description: option<string>,
        server-id: option<string>,
        source-name: option<string>,
        format: string,
    }

    /// Content that can be sent in a message.
    variant message-content {
        text(string),
        with-attachments(text-with-attachments),
    }

    /// Text message with attachments.
    record text-with-attachments {
        text: string,
        attachments: list<attachment>,
    }

    /// A chat message.
    record message {
        id: string,
        author: user,
        content: message-content,
        /// RFC3339 timestamp string.
        timestamp: string,
        attachments: list<attachment>,
        reactions: list<reaction>,
        reply-to: option<message-reply-preview>,
        edited: bool,
        /// If this message spawned a thread, lightweight info about it.
        thread: option<thread-info>,
    }

    /// Query options for fetching messages.
    record message-query {
        before: option<string>,
        after: option<string>,
        around: option<string>,
        limit: option<u32>,
    }

    /// Query options for backend-native message search.
    record message-search-query {
        text: string,
        channel-id: option<string>,
        server-id: option<string>,
        author-id: option<string>,
        has-link: bool,
        mentions-user-id: option<string>,
        limit: option<u32>,
    }

    /// A search hit returned by a backend.
    record message-search-hit {
        channel-id: string,
        channel-name: option<string>,
        server-id: option<string>,
        message: message,
    }

    /// How a backend exposes account signup to users.
    ///
    /// `external(url)` — open the given URL in the system browser.
    /// `in-app(route)` — navigate to a plugin-declared in-app route.
    /// `not-supported` — no signup affordance (demo, read-only feeds).
    variant signup-method {
        /// Open this URL in the host's external browser.
        external(string),
        /// Navigate to this plugin-declared in-app route.
        in-app(string),
        /// No signup link supported.
        not-supported,
    }

    /// An authenticated session with a backend.
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record session {
        id: string,
        user: user,
        token: string,
        backend: string,
        icon-emoji: option<string>,
        instance-id: string,
        backend-url: option<string>,
    }

    /// Authentication credentials for logging in.
    variant auth-credentials {
        token(string),
        email-password(email-password-creds),
        oauth(string),
        device-code(string),
        poly-server(poly-server-creds),
    }

    /// Email + password credentials.
    record email-password-creds {
        email: string,
        password: string,
    }

    /// Poly server Ed25519 challenge-response credentials.
    record poly-server-creds {
        server-url: string,
        private-key-bytes: list<u8>,
        username: option<string>,
        email: option<string>,
        display-name: option<string>,
        selected-user-id: option<string>,
        is-signup: bool,
    }

    /// A group chat (multi-user DM).
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record group {
        id: string,
        members: list<user>,
        name: option<string>,
        last-message: option<message>,
        backend: string,
        account-id: string,
    }

    /// A direct message channel.
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record dm-channel {
        id: string,
        user: user,
        last-message: option<message>,
        unread-count: u32,
        backend: string,
        account-id: string,
    }

    /// The kind of notification.
    variant notification-kind {
        mention(mention-info),
        friend-request(string),
        server-invite(string),
        voice-channel-invite(voice-invite-info),
        reauth-required(string),
        other(string),
    }

    /// Info for a mention notification.
    record mention-info {
        channel-id: string,
        message-id: string,
    }

    /// Info for a voice channel invite notification.
    record voice-invite-info {
        server-id: string,
        channel-id: string,
        channel-name: string,
        inviter-user-id: string,
    }

    /// A notification from a backend.
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record notification {
        id: string,
        kind: notification-kind,
        backend: string,
        account-id: string,
        /// RFC3339 timestamp.
        timestamp: string,
        read: bool,
        preview: string,
    }

    /// A user connected to a voice or video channel.
    record voice-participant {
        user: user,
        is-muted: bool,
        is-deafened: bool,
        is-streaming: bool,
        is-video-on: bool,
        is-speaking: bool,
    }

    /// The local user's voice connection state.
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record voice-connection {
        channel-id: string,
        server-id: string,
        channel-name: string,
        server-name: string,
        backend: string,
        account-id: string,
        instance-id: string,
        is-muted: bool,
        is-deafened: bool,
        is-streaming: bool,
        is-video-on: bool,
    }

    /// Identifies a configured account.
    ///
    /// D17 — `backend` is a plugin-provided slug string.
    record account {
        id: string,
        backend: string,
        display-name: string,
        connected: bool,
    }

    /// The live connection state of a backend account.
    variant connection-status {
        connected,
        connecting,
        disconnected,
        error(string),
    }

    /// Errors from client operations.
    variant client-error {
        auth-failed(string),
        network(string),
        not-found(string),
        rate-limited(u64),
        permission-denied(string),
        internal(string),
        not-supported(string),
    }

    /// HTTP response from the host.
    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    // ─── Event Types ───────────────────────────────────────────

    /// A real-time event from a messenger backend.
    ///
    /// D19 — `sidebar-invalidated` signals that a plugin's sidebar
    /// declaration has changed; the host re-fetches the sidebar.
    variant client-event {
        message-received(message-received-event),
        message-edited(message-edited-event),
        message-deleted(message-deleted-event),
        presence-changed(presence-changed-event),
        notification-received(notification),
        typing-started(typing-started-event),
        channel-updated(channel),
        server-updated(server),
        friend-request-received(user),
        connection-state-changed(connection-state-changed-event),
        voice-user-joined(voice-channel-event),
        voice-user-left(voice-user-left-event),
        voice-state-updated(voice-channel-event),
        /// D19 — plugin signals "re-fetch my sidebar declaration".
        /// No payload: the host calls `client-sidebar.get-sidebar-declaration`.
        sidebar-invalidated,
    }

    record message-received-event {
        channel-id: string,
        message: message,
    }

    record message-edited-event {
        channel-id: string,
        message: message,
    }

    record message-deleted-event {
        channel-id: string,
        message-id: string,
    }

    record presence-changed-event {
        user-id: string,
        status: presence-status,
    }

    record typing-started-event {
        channel-id: string,
        user-id: string,
        /// RFC3339 timestamp.
        timestamp: string,
    }

    /// D17 — `backend` is a plugin-provided slug string.
    record connection-state-changed-event {
        backend: string,
        connected: bool,
    }

    record voice-channel-event {
        channel-id: string,
        participant: voice-participant,
    }

    record voice-user-left-event {
        channel-id: string,
        user-id: string,
    }
}

// ─── Host API (imports — host provides to plugin) ──────────────────

/// Capabilities the host provides to plugins (syscall-like interface).
///
/// Plugins have ZERO direct network or filesystem access. All I/O goes
/// through these host-mediated functions. The host can restrict, rate-limit,
/// and sandbox each plugin's access.
interface host-api {
    use types.{log-level, http-response, client-event, exec-output};

    /// Make an HTTP request.
    ///
    /// Returns an HTTP response with status, headers, and body.
    /// The host may restrict which URLs the plugin can access.
    http-request: func(
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    ) -> result<http-response, string>;

    /// Open a persistent WebSocket connection. Returns a handle ID.
    ///
    /// The host manages the connection. When data arrives on the WebSocket,
    /// the host calls the guest's `handle-ws-data` export with the raw bytes.
    /// The guest parses the protocol-specific data and calls `emit-event`
    /// to push parsed events back to the host.
    websocket-connect: func(
        url: string,
        headers: list<tuple<string, string>>,
    ) -> result<u64, string>;

    /// Send data on a WebSocket.
    websocket-send: func(handle: u64, data: list<u8>) -> result<_, string>;

    /// Close a WebSocket connection.
    websocket-close: func(handle: u64) -> result<_, string>;

    /// Emit a real-time event to the host.
    ///
    /// Called by the guest when it has parsed incoming data (from WebSocket
    /// or HTTP responses) into a structured event. The host delivers it to
    /// the UI immediately — no polling, no queuing.
    ///
    /// Typical flow:
    ///   1. Host receives WebSocket data → calls guest's `handle-ws-data`
    ///   2. Guest parses protocol bytes → calls `emit-event` with result
    ///   3. Host forwards event to `event_stream()` consumers
    emit-event: func(event: client-event);

    /// Read a value from plugin-scoped key-value storage.
    storage-get: func(key: string) -> option<list<u8>>;

    /// Write a value to plugin-scoped key-value storage.
    storage-set: func(key: string, value: list<u8>) -> result<_, string>;

    /// Delete a key from plugin-scoped key-value storage.
    storage-delete: func(key: string) -> result<_, string>;

    /// Read a value from per-account plugin-scoped storage.
    ///
    /// Keys in this namespace are DISJOINT from the plugin-global `storage-*`
    /// namespace — a plugin that serves multiple accounts can scope caches,
    /// tokens, and last-read markers per account without key collisions.
    account-storage-get: func(account: string, key: string) -> option<list<u8>>;

    /// Write a value to per-account plugin-scoped storage.
    account-storage-set: func(account: string, key: string, value: list<u8>) -> result<_, string>;

    /// Delete a key from per-account plugin-scoped storage.
    account-storage-delete: func(account: string, key: string) -> result<_, string>;

    /// Log a message through the host's logging system.
    log: func(level: log-level, message: string);

    /// Get the current wall-clock time as an RFC3339 string.
    get-current-time: func() -> string;

    /// Spawn a subprocess and wait for it to exit.
    ///
    /// Args are passed directly to the process — there is NO shell involved,
    /// so `&&`, `|`, `;`, `$`, backticks, and other shell metacharacters are
    /// just literal characters in argv. Plugins declare which programs they
    /// invoke via `get-plugin-manifest` for user transparency, but the host
    /// does not enforce that declaration at runtime; the trust boundary is
    /// "you installed this plugin."
    exec-command: func(
        program: string,
        args: list<string>,
    ) -> result<exec-output, string>;

    /// D20 — the set of host-owned route kinds a plugin may target.
    ///
    /// Plugins never construct raw route strings. They call `build-route`
    /// with one of these kinds plus the relevant params; the host returns
    /// a validated route string which the plugin hands back via
    /// `action-outcome::navigate`.
    enum route-kind {
        server-home,
        channel,
        dm,
        friends,
        notifications,
        settings-account,
        settings-server,
        settings-channel,
        voice,
        search,
        sidebar-item,
    }

    /// D20 — errors returned by `build-route` when the plugin supplies
    /// an unknown kind or an invalid / missing parameter.
    variant route-build-error {
        unknown-kind,
        missing-param(string),
        invalid-param(string),
    }

    /// D20 — plugin builds route strings via the host. Never constructs raw.
    ///
    /// Params are a list of key/value tuples (kebab-case keys; URL-encoded
    /// values). The host validates both the kind and the required params
    /// for that kind, and returns a route string ready to pass to
    /// `action-outcome::navigate`.
    build-route: func(
        kind: route-kind,
        params: list<tuple<string, string>>,
    ) -> result<string, route-build-error>;
}

// ─── Client UI Common Types ────────────────────────────────────────

/// Shared types used across the client-UI surfaces (menus, settings,
/// sidebar, views, composer). Factored out so each surface can `use`
/// them without circular dependencies.
interface client-ui-common {
    /// D4 — sanitized HTML rendered in a shadow-root by the host.
    /// Allowlist is documented in plan §4.6.
    record custom-block {
        sanitized-html: string,
        stylesheet: option<string>,
        max-height-px: option<u32>,
    }

    /// D27 — icon for menu items, sidebar items, settings sections,
    /// composer buttons. Either an emoji string OR a sanitized SVG
    /// path string (host strips scripts + event handlers).
    variant icon-source {
        emoji(string),
        svg(string),
    }

    /// D23 — structured paged-data cursor.
    record cursor {
        kind: cursor-kind,
        value: string,
    }

    /// D23 — cursor payload shape; covers offset-, timestamp-, id-,
    /// and opaque-cursor paging models used across backends.
    enum cursor-kind {
        offset,
        timestamp,
        id,
        opaque,
    }
}

// ─── Client Menus ──────────────────────────────────────────────────

/// D11 — plugin-declared context-menu items merged into host context menus.
///
/// Host calls `get-context-menu-items` every time the user opens a menu
/// (D24 — no caching). Items carry opaque kebab-case action IDs (D14, D25)
/// that the host dispatches back via `invoke-context-action`.
interface client-menus {
    use types.{client-error};
    use client-ui-common.{custom-block, icon-source};

    /// D6 — what the menu is attached to. Host passes this to
    /// `get-context-menu-items` along with the target's id.
    enum menu-target-kind {
        category,
        channel,
        dm,
        message,
        server,
        user,
    }

    /// D6 — named slots in host context menus. Plugin items declare
    /// which slot they occupy; host inserts separators between occupied
    /// slots.
    enum menu-slot {
        /// above host items
        top,
        /// after Favorites block, before middle separators
        after-favorites,
        /// above Leave/Remove
        before-leave,
        /// below host items
        bottom,
    }

    /// Variant of a menu item — governs rendering + interaction.
    enum menu-item-variant {
        /// Standard clickable row.
        normal,
        /// Red / destructive styling (Leave, Block, Delete).
        destructive,
        /// Row is a submenu header; `submenu` field is populated.
        submenu-header,
        /// Non-clickable row that renders an optional `custom-block`.
        info-block,
    }

    /// D6 / D14 / D25 / D27 / D28 — a single plugin-declared menu item.
    ///
    /// Submenus (D28 — unbounded depth): WIT forbids recursive records, so
    /// menus are returned as a flat list with `parent-id` pointers. The host
    /// reconstructs the tree by linking children (items whose `parent-id`
    /// equals some parent's `id`) under their parents. Items with
    /// `parent-id == none` are top-level. Cycle detection is the host's job;
    /// items referencing an unknown `parent-id` are dropped with a warning.
    record menu-item {
        /// Opaque plugin action id (D14); kebab-case (D25). Unique within
        /// a single `get-context-menu-items` response.
        id: string,
        /// D28 — `some(parent.id)` to place this item under a
        /// submenu-header parent; `none` for top-level items.
        parent-id: option<string>,
        /// D6 — which host slot this item lives in (only meaningful for
        /// top-level items — ignored when `parent-id` is set).
        slot: menu-slot,
        /// FTL key: `plugin-<id>-menu-<key>-label` (D21 lint-checked).
        label-key: string,
        /// D27 — emoji OR sanitized SVG.
        icon: option<icon-source>,
        /// Rendering style: normal | destructive | submenu-header | info-block.
        item-variant: menu-item-variant,
        shortcut: option<string>,
        /// Only populated when `item-variant == info-block` (D4).
        block: option<custom-block>,
    }

    /// D16 — toast tones for `action-outcome::toast`.
    enum toast-tone {
        info,
        success,
        warning,
        error,
    }

    /// D16 — a toast emitted by an action. `label-key` is resolved via
    /// the plugin's FTL bundle.
    record toast-payload {
        label-key: string,
        tone: toast-tone,
    }

    /// D16 — jump target for `action-outcome::open-settings`. Scope is
    /// one of the string forms of `client-settings.settings-scope`
    /// (`"account-global"`, `"per-server"`, …).
    record settings-anchor {
        scope: string,
        scope-id: string,
        section-key: string,
    }

    /// D16 — reference to a plugin-declared modal (reserved for future use).
    record modal-ref {
        modal-id: string,
        /// Opaque JSON blob passed back to the plugin on invocation.
        context: string,
    }

    /// D16 — handle for a pending async action. Passed back to
    /// `poll-action` by the host until the action resolves.
    record pending-handle {
        /// Plugin-opaque; the host returns it verbatim via `poll-action`.
        action-ref: string,
        /// FTL key for "Saving…" / "Uploading…".
        progress-hint: option<string>,
    }

    /// D16 / D30 — outcome of an invoked plugin action.
    variant action-outcome {
        /// No UI change.
        noop,
        /// D16 — slow op; host polls via `poll-action`.
        pending(pending-handle),
        /// D16 — done, no UI change.
        completed,
        /// D30 — re-fetch just the target object.
        refresh-target,
        /// Host rebuilds the sidebar.
        refresh-sidebar,
        /// D20 — must be built via `host-api.build-route`.
        navigate(string),
        /// Show an FTL-keyed toast.
        toast(toast-payload),
        /// Jump into a settings-section.
        open-settings(settings-anchor),
        /// Open a plugin-declared modal.
        open-modal(modal-ref),
    }

    /// D24 — host calls this every time the user opens a context menu.
    /// Plugin returns ALL items for the target; host merges with its
    /// universal items (Copy ID, Favorites, Leave, Mark Read — D10).
    get-context-menu-items: func(
        target: menu-target-kind,
        target-id: string,
    ) -> result<list<menu-item>, client-error>;

    /// D14 / D22 — dispatch a plugin action. Unknown ids return
    /// `client-error::not-found(action-id)`.
    invoke-context-action: func(
        action-id: string,
        target: menu-target-kind,
        target-id: string,
    ) -> result<action-outcome, client-error>;

    /// D16 — poll a pending async action for its final outcome.
    poll-action: func(handle: pending-handle) -> result<action-outcome, client-error>;
}

// ─── Client Settings ───────────────────────────────────────────────

/// D11 / D18 — plugin-declared settings sections (account-global,
/// per-server, per-channel, per-user). Replaces the removed
/// `plugin-metadata.get-settings-schema`. `setting-kind` and
/// `setting-descriptor` live here (moved from `plugin-metadata`).
interface client-settings {
    use types.{client-error};
    use client-ui-common.{custom-block};

    /// D18 — the type of setting control to render.
    enum setting-kind {
        /// Boolean toggle / checkbox.
        toggle,
        /// Single-line text input.
        text-input,
        /// Dropdown with a fixed list of options.
        select,
        /// Numeric slider (min / max / step encoded in `extra`).
        slider,
        /// Read-only informational label row.
        info-label,
    }

    /// D18 — one entry in a plugin's settings schema.
    ///
    /// `key` is the storage key AND the FTL key suffix for label/description.
    /// FTL lookup: `plugin-<plugin-id>-setting-<key>-label`
    ///             `plugin-<plugin-id>-setting-<key>-desc`   (optional)
    /// Storage is owned by the plugin via `host-api.storage-*` (D15).
    record setting-descriptor {
        /// Unique key within this plugin (snake_case). Used as storage key.
        key: string,
        /// The kind of widget to render.
        kind: setting-kind,
        /// JSON-serialized default value (e.g. "true", "\"option-a\"", "42").
        default-value: string,
        /// For `select` kind: JSON array of option values. For `slider`:
        /// JSON object `{"min":0,"max":100,"step":1}`. Empty otherwise.
        extra: string,
    }

    /// D11 — where a settings section applies.
    enum settings-scope {
        /// The plugin's account-wide settings panel. Replaces the legacy
        /// `get-settings-schema` surface (D18).
        account-global,
        per-server,
        per-channel,
        per-user,
    }

    /// D11 — one settings section; scope + section-key + fields.
    record settings-section {
        scope: settings-scope,
        /// FTL key suffix + URL anchor.
        section-key: string,
        icon: option<string>,
        fields: list<setting-descriptor>,
        /// Optional informational panel (D4).
        info-block: option<custom-block>,
    }

    /// Return every settings section this plugin contributes, across
    /// every scope. Host filters by scope at render time. Return an
    /// empty list if the plugin has no settings.
    get-settings-sections: func() -> result<list<settings-section>, client-error>;

    /// D15 — plugin owns storage via `host-api.storage-*`. This function
    /// is the plugin's accessor; internally it reads from its own KV
    /// namespace. Returns a JSON-encoded value.
    get-setting-value: func(
        scope: settings-scope,
        /// server-id, channel-id, user-id, or "" for `account-global`.
        scope-id: string,
        key: string,
    ) -> result<string, client-error>;

    /// D15 — write a JSON-encoded value to the plugin's KV namespace.
    set-setting-value: func(
        scope: settings-scope,
        scope-id: string,
        key: string,
        /// JSON-encoded value.
        value: string,
    ) -> result<_, client-error>;
}

// ─── Client Config ─────────────────────────────────────────────────

/// Host-defined, uniform-across-backends client configuration.
///
/// Distinct from `client-settings` which is plugin-defined per-plugin
/// schema. This interface covers the version string the plugin
/// advertises on the wire and any backend-specific "mechanisms" the
/// plugin supports (captcha-sandbox, sliding-sync, browser-shim, …).
///
/// All methods carry default impls in the Rust trait so existing
/// plugins compiled against the old WIT continue to load — they
/// surface as "version: <plugin default>" and "mechanisms: []".
interface client-config {
    use types.{client-error};

    /// Optional host capability a mechanism may require to function.
    ///
    /// When a mechanism declares `requires-host-cap = some(sandbox-browser)`
    /// and the host doesn't advertise that cap, the UI MUST disable
    /// the toggle and the plugin MUST treat the mechanism as off.
    variant host-cap {
        /// Open a sub-browser the user can interact with for
        /// challenges (Discord captcha, OAuth flows). Stub in v1.
        sandbox-browser,
        /// Native system tray icon (future).
        system-tray,
        /// OS-level notifications (future).
        os-notifications,
    }

    /// One toggleable "mechanism" the plugin supports — a named code
    /// path the user can opt into or out of. IDs are plugin-stable
    /// (the plugin is free to define them) but should be kebab-case.
    record mechanism {
        /// Stable ID. Storage key suffix.
        /// Example: "captcha-sandbox", "sliding-sync", "browser-shim".
        id: string,
        /// FTL key for the human-readable label.
        /// Example: "plugin-discord-mechanism-captcha-sandbox-label".
        name-key: string,
        /// Current on/off state — already merged with the host-stored
        /// override; the plugin returns the effective value.
        enabled: bool,
        /// If `some`, the mechanism only functions when the host
        /// advertises the matching capability. The UI disables the
        /// toggle when the cap is absent.
        requires-host-cap: option<host-cap>,
        /// Optional FTL key for a longer description shown on hover.
        description-key: option<string>,
    }

    /// Return the version string the plugin will advertise on the
    /// next outbound request. After the host sets an override via
    /// `set-client-version-override(some(...))`, this MUST return
    /// the override string. With no override set, this returns the
    /// plugin's hardcoded default.
    get-client-version: func() -> string;

    /// Set or clear the version override. `none` clears.
    /// The host stores the override in `poly_kv` and re-injects it
    /// into the plugin via `host-api.storage-get` on next plugin
    /// load; the plugin reads it on init and merges over its default.
    set-client-version-override: func(
        override: option<string>,
    ) -> result<_, client-error>;

    /// Return the full mechanism inventory for this backend. Empty
    /// list is legal (most backends in v1).
    get-client-mechanisms: func() -> result<list<mechanism>, client-error>;

    /// Toggle one mechanism on or off by ID. Plugin persists via
    /// `host-api.storage-set` under its own KV namespace (mirror of
    /// the host-owned `client.config.<id>.mechanism.<m>` key) and
    /// returns the new state via `get-client-mechanisms`.
    set-client-mechanism: func(
        id: string,
        enabled: bool,
    ) -> result<_, client-error>;
}

// ─── Client Sidebar ────────────────────────────────────────────────

/// D11 / D5 / D19 — plugin-declared sidebar layout. The host ships five
/// stock layouts; plugins may also go fully custom with `sections`.
/// Refresh is event-driven via `client-event::sidebar-invalidated` (D19).
interface client-sidebar {
    use types.{client-error};
    use client-ui-common.{custom-block, icon-source};
    use client-menus.{action-outcome};

    /// D5 — stock layout kinds the host renders natively. `custom` asks
    /// the host to render `sidebar-declaration.sections` verbatim.
    enum sidebar-layout-kind {
        /// Discord/Stoat/Teams/poly-native.
        channel-list,
        /// Matrix: spaces containing rooms.
        spaces-rooms,
        /// Lemmy/Reddit: subscribed communities.
        communities,
        /// HN/Mastodon: feed tabs (Top/New/Best/Ask/Show/Jobs).
        feed,
        /// GitHub/Forgejo: repo tree.
        repo-tree,
        /// Plugin supplies sections explicitly.
        custom,
    }

    /// D5 — the shape a sidebar-item navigates to when clicked.
    enum sidebar-route-kind {
        /// Opens chat-view.
        channel,
        /// Opens `client-views` forum layout.
        forum,
        /// Opens `client-views` feed layout.
        feed,
        /// Opens code-browser.
        code,
        /// Opens issue-list view.
        issue-tracker,
        /// Invokes a plugin-declared modal.
        modal,
        /// Opens in system browser.
        external,
        /// Plugin returns a `client-views::view-descriptor` on click.
        custom-view,
    }

    /// D5 — a single row in the sidebar.
    ///
    /// Nesting: WIT forbids recursive records, so sidebar items are
    /// returned in a flat list per section with `parent-id` pointers.
    /// The host reconstructs the tree (analogous to `menu-item`
    /// submenu handling). Items with `parent-id == none` are section
    /// roots; children reference a parent by id.
    record sidebar-item {
        id: string,
        /// `some(parent.id)` to nest under another sidebar item; `none`
        /// for section-root rows.
        parent-id: option<string>,
        label-key: string,
        icon: option<icon-source>,
        /// "new", "3", etc. Raw string; not an FTL key.
        badge: option<string>,
        route-kind: sidebar-route-kind,
    }

    /// D5 — a grouping of sidebar items (optionally with a header).
    record sidebar-section {
        /// FTL key; None for anonymous (header-less) group.
        header-key: option<string>,
        collapsible: bool,
        default-collapsed: bool,
        items: list<sidebar-item>,
    }

    /// D5 — top-level sidebar declaration returned by the plugin.
    record sidebar-declaration {
        layout: sidebar-layout-kind,
        /// Populated when `layout == custom`.
        sections: list<sidebar-section>,
        /// Optional info panel at top (D4).
        header-block: option<custom-block>,
    }

    /// D19 — return the current sidebar declaration. Host re-calls on
    /// receipt of `client-event::sidebar-invalidated`.
    get-sidebar-declaration: func() -> result<sidebar-declaration, client-error>;

    /// D14 / D25 — dispatch a sidebar-item click (kebab-case `id`).
    invoke-sidebar-action: func(
        action-id: string,
    ) -> result<action-outcome, client-error>;
}

// ─── Client Views ──────────────────────────────────────────────────

/// D11 / D5 — plugin-declared non-chat views (forum, feed, issue tracker).
/// The host ships a closed set of body engines (list / card-grid / tree /
/// split); the plugin composes them via a `view-descriptor`.
interface client-views {
    use types.{client-error};
    use client-ui-common.{custom-block, cursor};
    use client-menus.{menu-item, menu-target-kind};

    /// D5 — closed set of body engines the host can render.
    enum view-kind {
        /// Generic list (posts, issues, stories).
        flat-list,
        /// Post-card grid (Reddit, Mastodon).
        card-grid,
        /// Nested (Lemmy threaded).
        tree,
        /// Master-detail.
        split,
    }

    /// D5 — a single selectable option in a toolbar (sort/filter/tab).
    record toolbar-option {
        id: string,
        label-key: string,
        icon: option<string>,
        default-selected: bool,
    }

    /// D5 — view header: titles + optional info block.
    record view-header {
        title-key: option<string>,
        subtitle-key: option<string>,
        info-block: option<custom-block>,
    }

    /// D5 — view toolbar: sort / filter / tabs / action items.
    record view-toolbar {
        /// Hot / Top / New / Best / …
        sort-options: list<toolbar-option>,
        /// Week / Month / Year / All.
        filter-options: list<toolbar-option>,
        /// Issues / PRs / Discussions.
        tabs: list<toolbar-option>,
        /// Reuses `menu-item` from `client-menus`.
        action-items: list<menu-item>,
    }

    /// D5 — bindings from feed-field names to row-template positions.
    record row-template {
        /// e.g. "title".
        primary-field: string,
        /// e.g. "url" / "author".
        secondary-field: option<string>,
        /// e.g. "score · comments · age".
        meta-field: option<string>,
        icon-field: option<string>,
    }

    /// D5 — list body: row template + page size.
    record list-spec {
        row-template: row-template,
        page-size: u32,
    }

    /// D5 — card body (Reddit/Mastodon style).
    record card-spec {
        primary-field: string,
    }

    /// D5 — threaded tree body (Lemmy-style comments).
    record tree-spec {
        root-page-size: u32,
        max-depth: u32,
    }

    /// D5 — split body: list on one side, detail on the other.
    record split-spec {
        list-side: list-spec,
        detail-view-kind: view-kind,
    }

    /// D5 — which body engine to render.
    variant view-body {
        list-body(list-spec),
        card-body(card-spec),
        tree-body(tree-spec),
        split-body(split-spec),
    }

    /// D5 — top-level descriptor for a non-chat view of a channel.
    record view-descriptor {
        kind: view-kind,
        header: option<view-header>,
        toolbar: option<view-toolbar>,
        body: view-body,
    }

    /// D5 — one row in a paged view. `primary-text` etc. are raw content,
    /// NOT FTL keys. `context-menu-target-kind` is what right-clicking
    /// this row targets (so the host can call
    /// `client-menus::get-context-menu-items`).
    record view-row {
        id: string,
        primary-text: string,
        secondary-text: option<string>,
        meta-text: option<string>,
        icon: option<string>,
        badge: option<string>,
        context-menu-target-kind: menu-target-kind,
    }

    /// D23 — one page of rows plus an optional next-cursor.
    record view-rows-page {
        rows: list<view-row>,
        next-cursor: option<cursor>,
    }

    /// D5 — detail payload for `split` views.
    record view-detail {
        /// Plugin-authored content, sanitized by the host (D4).
        body-block: custom-block,
        /// Optional threaded comments section.
        comments-section: option<tree-spec>,
    }

    /// Fetch the account-level overview view descriptor.
    ///
    /// Each backend supplies its own per-account "overview" view that the
    /// host renders at `/{backend}/{instance}/{account}/overview`. This is
    /// the default landing page for every account unless the backend
    /// declares a different `landing` capability. Plugin-defined content:
    /// repo grids for forge backends, community / server cards for chat
    /// backends, curated story lists for read-only feeds, etc.
    get-account-overview-view: func() -> result<view-descriptor, client-error>;

    /// D5 — fetch the channel's view descriptor.
    get-channel-view: func(
        channel-id: string,
    ) -> result<view-descriptor, client-error>;

    /// D23 — paged data feed. Host calls on scroll with the previous
    /// page's `next-cursor` (or `None` for the first page).
    get-view-rows: func(
        channel-id: string,
        cursor: option<cursor>,
        sort-id: option<string>,
        filter-id: option<string>,
        tab-id: option<string>,
    ) -> result<view-rows-page, client-error>;

    /// D5 — detail fetch for split views.
    get-view-detail: func(
        channel-id: string,
        row-id: string,
    ) -> result<view-detail, client-error>;
}

// ─── Client Composer ───────────────────────────────────────────────

/// D11 / D8 — plugin-contributed composer-toolbar buttons and
/// per-message action items. Everything else in the chat view remains
/// host-owned.
interface client-composer {
    use types.{client-error};
    use client-menus.{menu-item, action-outcome};

    /// D8 — where a composer button appears relative to the input.
    enum composer-slot {
        /// File upload / attach.
        left-of-input,
        /// Send / emoji / voice.
        right-of-input,
        /// Sticker drawer toggle.
        above-input,
    }

    /// D8 — a single plugin-contributed composer button.
    record composer-button {
        id: string,
        label-key: string,
        icon: string,
        position: composer-slot,
    }

    /// D8 — composer-toolbar buttons for the given channel.
    get-composer-buttons: func(
        channel-id: string,
    ) -> result<list<composer-button>, client-error>;

    /// D8 — per-message actions, merged into the message hover/overflow
    /// menu. Reuses `menu-item` from `client-menus`.
    get-message-actions: func(
        channel-id: string,
        message-id: string,
    ) -> result<list<menu-item>, client-error>;

    /// D14 / D25 — dispatch a composer button action.
    invoke-composer-action: func(
        action-id: string,
        channel-id: string,
    ) -> result<action-outcome, client-error>;

    /// D14 / D25 — dispatch a per-message action.
    invoke-message-action: func(
        action-id: string,
        channel-id: string,
        message-id: string,
    ) -> result<action-outcome, client-error>;
}

// ─── Messenger Client (exports — plugin provides to host) ──────────

/// The messenger client interface that every plugin must implement.
///
/// Maps 1:1 to the ClientBackend trait in poly-client.
interface messenger-client {
    use types.{
        auth-credentials,
        session,
        client-error,
        server,
        channel,
        message-content,
        message,
        message-query,
        message-search-query,
        message-search-hit,
        custom-emoji,
        sticker-item,
        user,
        group,
        dm-channel,
        notification,
        voice-participant,
        presence-status,
        client-event,
        backend-capabilities,
        file-entry,
        file-content,
        forum-post,
        forum-sort-order,
        thread-info,
        signup-method,
    };

    /// Authenticate with the backend.
    authenticate: func(credentials: auth-credentials) -> result<session, client-error>;

    /// Log out and invalidate the current session.
    logout: func() -> result<_, client-error>;

    /// Check if the client is currently authenticated.
    is-authenticated: func() -> bool;

    /// Get all servers/communities the user has joined.
    get-servers: func() -> result<list<server>, client-error>;

    /// Get a specific server by ID.
    get-server: func(id: string) -> result<server, client-error>;

    /// Get all channels in a server.
    get-channels: func(server-id: string) -> result<list<channel>, client-error>;

    /// Get a specific channel by ID.
    get-channel: func(id: string) -> result<channel, client-error>;

    /// Send a message to a channel.
    send-message: func(channel-id: string, content: message-content) -> result<message, client-error>;

    /// Send a reply to an existing message.
    send-reply-message: func(channel-id: string, reply-to-message-id: string, content: message-content) -> result<message, client-error>;

    /// Get messages from a channel with query options.
    get-messages: func(channel-id: string, query: message-query) -> result<list<message>, client-error>;

    /// Search messages using the backend's native search implementation.
    search-messages: func(query: message-search-query) -> result<list<message-search-hit>, client-error>;

    /// Get pinned messages for a channel.
    get-pinned-messages: func(channel-id: string) -> result<list<message>, client-error>;

    /// Get the custom emoji usable in a channel.
    get-available-emojis: func(channel-id: string) -> result<list<custom-emoji>, client-error>;

    /// Get the stickers usable in a channel.
    get-available-stickers: func(channel-id: string) -> result<list<sticker-item>, client-error>;

    /// Pin or unpin a message in a channel.
    set-message-pinned: func(channel-id: string, message-id: string, pinned: bool) -> result<_, client-error>;

    /// Get a user by ID.
    get-user: func(user-id: string) -> result<user, client-error>;

    /// Get the authenticated user's friend list.
    get-friends: func() -> result<list<user>, client-error>;

    /// Get members of a channel.
    get-channel-members: func(channel-id: string) -> result<list<user>, client-error>;

    /// Get all group chats.
    get-groups: func() -> result<list<group>, client-error>;

    /// Remove a user from a group DM.
    remove-group-member: func(group-id: string, user-id: string) -> result<_, client-error>;

    /// Add a user to a group DM.
    add-group-member: func(group-id: string, user-id: string) -> result<_, client-error>;

    /// Get all DM channels.
    get-dm-channels: func() -> result<list<dm-channel>, client-error>;

    /// Open or create a DM channel with the target user.
    open-direct-message-channel: func(user-id: string) -> result<dm-channel, client-error>;

    /// Open the authenticated user's Saved Messages / self-DM channel.
    open-saved-messages-channel: func() -> result<dm-channel, client-error>;

    /// Get the user's notifications.
    get-notifications: func() -> result<list<notification>, client-error>;

    /// Get voice participants in a channel.
    get-voice-participants: func(channel-id: string) -> result<list<voice-participant>, client-error>;

    /// Get a user's online presence status.
    get-presence: func(user-id: string) -> result<presence-status, client-error>;

    /// Set the authenticated user's presence status.
    set-presence: func(status: presence-status) -> result<_, client-error>;

    /// Handle incoming WebSocket data from the host.
    ///
    /// Called by the host whenever data arrives on a WebSocket connection
    /// opened via `websocket-connect`. The guest parses the raw bytes
    /// according to its backend's protocol (e.g., Matrix sync JSON,
    /// Revolt Bonfire events, Discord Gateway payloads) and calls
    /// `emit-event` on the host for each parsed event.
    ///
    /// This replaces the old poll-based model — events flow push-to-push
    /// with zero polling overhead.
    handle-ws-data: func(handle: u64, data: list<u8>);

    /// D17 — the backend slug for this plugin (e.g. "discord", "matrix",
    /// "lemmy"). Returned as a string because the legacy `backend-type`
    /// enum has been removed.
    get-backend-type: func() -> string;

    /// Human-readable name for this backend.
    get-backend-name: func() -> string;

    /// Capability flags for this backend (used by the UI to hide controls
    /// that don't apply, e.g. mic/speaker for read-only news backends).
    get-backend-capabilities: func() -> backend-capabilities;

    /// How this backend exposes account signup to users.
    ///
    /// `server-url` is passed for custom-server backends (Matrix, Stoat,
    /// Lemmy, Forgejo, GitHub Enterprise) so the signup URL can be
    /// parameterised. Hardcoded backends (Discord, Teams, …) ignore it.
    ///
    /// Old plugins that do not export this method are caught by the host
    /// trap handler and get `not-supported` substituted.
    get-signup-method: func(server-url: option<string>) -> result<signup-method, client-error>;

    /// List entries at the given path within a code-type channel.
    /// Path is repo-relative; empty string means the repo root.
    list-files: func(channel-id: string, path: string) -> result<list<file-entry>, client-error>;

    /// Read the raw bytes of a file in a code-type channel.
    read-file: func(channel-id: string, path: string) -> result<file-content, client-error>;

    /// Get forum posts (threads) in a forum channel, sorted by `sort`.
    /// `limit` caps the number returned; `none` uses the backend default.
    get-forum-posts: func(
        forum-channel-id: string,
        sort: forum-sort-order,
        limit: option<u32>,
    ) -> result<list<forum-post>, client-error>;

    /// Get all active (non-archived) threads in a server.
    get-active-threads: func(
        server-id: string,
    ) -> result<list<thread-info>, client-error>;

    /// Get archived threads for a parent channel (text or forum).
    /// `limit` caps the number returned; `none` uses the backend default.
    get-archived-threads: func(
        parent-channel-id: string,
        limit: option<u32>,
    ) -> result<list<thread-info>, client-error>;

    /// Create a new forum post (thread) in a forum channel.
    ///
    /// `title` is the post/thread name, `body` is the starter message text,
    /// and `tags` is the list of tag IDs to apply.  Backends that do not
    /// support post creation must return `not-supported`.
    create-forum-post: func(
        forum-channel-id: string,
        title: string,
        body: string,
        tags: list<string>,
    ) -> result<forum-post, client-error>;
}

// ─── Plugin Metadata (optional exports — host uses if present) ─────

/// Plugin metadata: localisation and display information.
///
/// D18 — the legacy `get-settings-schema` and its companion
/// `setting-kind` / `setting-descriptor` records have moved to the
/// `client-settings` interface. This interface now only covers
/// translations, display name, icon, and the informational manifest.
///
/// When present, the host uses it to:
/// - Load the plugin's FTL translation strings into the global i18n system
///   under the `plugin.<id>.*` namespace prefix.
///
/// ## Translation key convention
///
/// All FTL message IDs returned by `get-translations` MUST be prefixed with
/// `plugin-<plugin-id>-`. The host strips nothing — keys are used as-is.
/// Example for the demo plugin:
///   `plugin-demo-title = Demo Settings`
///   `plugin-demo-toggle-label = Enable Demo Data`
interface plugin-metadata {
    use types.{plugin-manifest};

    /// Return the raw FTL source text for a given locale code (e.g. "en", "de").
    ///
    /// Returns an empty string if the locale is not supported by this plugin,
    /// in which case the host falls back to the English bundle.
    get-translations: func(locale: string) -> string;

    /// Return the plugin's human-readable display name FTL key.
    ///
    /// The key must exist in the FTL returned by `get-translations("en")`.
    /// Example: "plugin-demo-title"
    get-display-name-key: func() -> string;

    /// Return the plugin's icon emoji or short string (e.g. "🧪").
    get-icon: func() -> string;

    /// Return the plugin's self-declared manifest.
    ///
    /// Purely informational — the host does NOT use this to enforce access
    /// at runtime. It exists so users can inspect (in the plugin settings
    /// panel) which subprocess programs and HTTP hosts a loaded plugin says
    /// it will use.
    get-plugin-manifest: func() -> plugin-manifest;
}

// ─── World Definition ──────────────────────────────────────────────

/// The complete plugin world — what a messenger plugin must satisfy.
///
/// Per D9 every plugin must export every client-UI surface. Per D18 the
/// old `plugin-metadata.get-settings-schema` has been folded into
/// `client-settings`. Per D17 the `backend-type` enum is gone; backend
/// identity is a slug string.
world messenger-plugin {
    import host-api;
    export messenger-client;
    export client-ui-common;
    export client-menus;
    export client-settings;
    export client-config;
    export client-sidebar;
    export client-views;
    export client-composer;
    export plugin-metadata;
}
